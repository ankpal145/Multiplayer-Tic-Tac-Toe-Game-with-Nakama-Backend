{
  "name": "tictactoe-nakama-server",
  "version": "1.0.0",
  "description": "Nakama server-side TypeScript runtime for multiplayer Tic-Tac-Toe",
  "main": "build/index.js",
  "scripts": {
    "build": "npx esbuild src/main.ts --bundle --outfile=build/index.js --target=es2020 --format=cjs",
    "build:watch": "npx esbuild src/main.ts --bundle --outfile=build/index.js --target=es2020 --format=cjs --watch"
  },
  "dependencies": {
    "nakama-runtime": "github:heroiclabs/nakama-common"
  },
  "devDependencies": {
    "esbuild": "^0.19.0",
    "typescript": "^5.3.0"
  }
}
